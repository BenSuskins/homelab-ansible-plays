# Hermes Agent configuration — rendered by tasks/docker/hermes.yml
# Model defaults to OpenRouter; the OPENROUTER_API_KEY env var supplies the key.
model:
  default: "anthropic/claude-opus-4.6"
  provider: "auto"
  base_url: "https://openrouter.ai/api/v1"

# Hermes connects only to the mcpjungle gateway, which federates every other MCP
# server (sonarr, radarr, and anything registered in future) behind one endpoint.
mcp_servers:
  mcpjungle:
    url: "http://{{ inventory_hostname }}:8090/mcp"
