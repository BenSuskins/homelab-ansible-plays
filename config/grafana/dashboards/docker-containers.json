{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "CPU Usage by Container",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "fillOpacity": 10, "lineWidth": 1, "stacking": { "mode": "none" } }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "calcs": ["mean", "max"], "sortBy": "Mean", "sortDesc": true }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{instance=~\"$host\",name=~\"$container\",name!=\"\"}[$__rate_interval])",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Memory Usage by Container",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 10, "lineWidth": 1, "stacking": { "mode": "none" } }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "calcs": ["mean", "max"], "sortBy": "Mean", "sortDesc": true }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{instance=~\"$host\",name=~\"$container\",name!=\"\"}",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Network RX by Container",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "fillOpacity": 10, "lineWidth": 1 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "calcs": ["mean"], "sortBy": "Mean", "sortDesc": true }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(container_network_receive_bytes_total{instance=~\"$host\",name=~\"$container\",name!=\"\"}[$__rate_interval])",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Network TX by Container",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "fillOpacity": 10, "lineWidth": 1 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "calcs": ["mean"], "sortBy": "Mean", "sortDesc": true }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(container_network_transmit_bytes_total{instance=~\"$host\",name=~\"$container\",name!=\"\"}[$__rate_interval])",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Top 10 CPU Consumers",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.5 },
              { "color": "red", "value": 0.8 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "topk(10, rate(container_cpu_usage_seconds_total{name!=\"\"}[$__rate_interval]))",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Top 10 Memory Consumers",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 536870912 },
              { "color": "red", "value": 1073741824 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "topk(10, container_memory_usage_bytes{name!=\"\"})",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["homelab", "docker"],
  "templating": {
    "list": [
      {
        "name": "host",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(container_cpu_usage_seconds_total{name!=\"\"}, instance)",
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "multi": true
      },
      {
        "name": "container",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(container_cpu_usage_seconds_total{instance=~\"$host\",name!=\"\"}, name)",
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "multi": true
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Docker Containers",
  "uid": "docker-containers",
  "version": 1
}
